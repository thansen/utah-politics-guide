# PostgreSQL connection string
DATABASE_URL=postgresql://localhost:5432/utah_politics

# Open Data Portal Basic Auth credentials (for proxy)
OPEN_DATA_AUTH=

# Utah Legislature API - get a developer token from https://le.utah.gov/asp/billsintro/developer.asp
UTAH_LEG_API_KEY=

# LegiScan API - register at https://legiscan.com/legiscan
LEGISCAN_API_KEY=

# UGRC GIS API - register at https://developer.mapserv.utah.gov
UGRC_API_KEY=

# Socrata App Token (optional, raises rate limits) - register at https://opendata.utah.gov
SOCRATA_APP_TOKEN=
